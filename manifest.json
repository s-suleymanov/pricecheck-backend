{
  "manifest_version": 3,
  "name": "PriceCheck Shopping",
  "version": "0.9.2.2",
  "description": "A more intelligent way to shop",
  "action": {
    "default_title": "Open PriceCheck"
  },
  "permissions": ["storage", "sidePanel"],
  "host_permissions": [
    "https://*.amazon.com/*",
    "https://*.target.com/*",
    "https://*.walmart.com/*",
    "https://*.bestbuy.com/*",
    "https://pricecheck-extension.onrender.com/*",
    "https://www.pricechecktool.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/logo.png"],
      "matches": [
        "*://*.amazon.com/*",
        "*://*.target.com/*",
        "*://*.walmart.com/*",
        "*://*.bestbuy.com/*"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.target.com/*",
        "*://*.walmart.com/*",
        "*://*.bestbuy.com/*"
      ],
      "js": ["content_observe.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/logo.png",
    "32": "icons/logo.png",
    "48": "icons/logo.png",
    "128": "icons/logo.png"
  }
}